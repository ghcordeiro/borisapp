# ============================================================
# boris.app — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# NUNCA commite .env.local no git
# ============================================================

# ── Banco de Dados ───────────────────────────────────────────
# URL de conexão PostgreSQL (com pooler para Vercel/Neon)
DATABASE_URL="postgresql://user:password@host:5432/boris_app?sslmode=require"

# URL direta sem pooler (para migrations com Prisma)
# Necessário apenas se usar Neon / PgBouncer
DIRECT_URL="postgresql://user:password@host:5432/boris_app?sslmode=require"

# ── NextAuth.js (Auth.js v5) ─────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-here"

# URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"

# ── Provedores OAuth (pelo menos um obrigatório) ─────────────

# Google OAuth
# Crie em: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# GitHub OAuth (opcional)
# Crie em: https://github.com/settings/applications/new
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV="development"
